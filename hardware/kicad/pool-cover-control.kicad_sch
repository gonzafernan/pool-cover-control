	(text "Reverse Polarity Protection\nP-channel MOSFET in series with the supply rail, gate clamped to −18V by a Zener diode,\nthat blocks current silently if the PSU is connected with reversed polarity."
		(exclude_from_sim no)
		(at 21.082 34.036 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left)
		)
		(uuid "416d152f-751f-4ee3-bcd7-04283ecdec65")
	)
	(text "Power Supply"
		(exclude_from_sim no)
		(at 27.432 21.844 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "62601751-ca8f-4804-935e-e5d07362ef72")
	)
	(text "Accepts 24V DC from the external PSU, protects against reverse polarity,\nfilters bulk transients, and generates the 3.3V logic rail via a step-down regulator.\n"
		(exclude_from_sim no)
		(at 20.828 25.654 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left)
		)
		(uuid "76db002e-2c7f-4927-aec6-54acfea7bb55")
	)
	(text "Step-down Regulator (3.3V power supply)\nSynchronous buck converter stepping 24V down to 3.3V at up to 600mA to power the MCU,\noptocouplers, and all logic circuitry."
		(exclude_from_sim no)
		(at 116.332 34.036 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left)
		)
		(uuid "c4e608c7-8f60-469d-9ab3-3225e4a92184")
	)
